               <string notr="true">QLabel{
	border:none;
}

QLabel#label_22{
	border: 2px solid rgb(70, 130, 180);
}

/* Table Widget Styles */
QTableWidget {
    background-color: #ffffff; /* White background for table cells */
    border: 2px solid #4682b4; /* Medium blue border around the table */
    border-radius: 5px;
    gridline-color: #4682b4; /* Medium blue grid lines */
    font-size: 16px;
    color: #1a3c6e; /* Dark blue text for cells */
    font-family: 'Comic Sans MS', 'Arial', sans-serif; /* Kid-friendly font */
}

/* Header Styles */
QHeaderView::section {
    background-color: #4682b4; /* Medium blue background for headers */
    color: #ffffff; /* White text for contrast */
    font-size: 18px; /* Larger font size for better visibility */
    font-weight: bold; /* Bold text for emphasis */
    border: 1px solid #1a3c6e; /* Dark blue border for sections */
    padding: 8px; /* Increased padding for more space */
    text-align: center; /* Center-align text in headers */
    height: 30px; /* Increase header height for better readability */
}

/* Fix for Horizontal Header Stretch */
QHeaderView::section:horizontal {
    min-width: 100px; /* Minimum width for each column header */
}

/* Fix for Vertical Header (Index Column) */
QHeaderView::section:vertical {
    background-color: #f0faff; /* Light blue for index column */
    font-weight: bold; /* Bold text for better visibility */
    font-size: 16px; /* Match the cell font size */
    color: #1a3c6e; /* Dark blue text */
    padding: 5px; /* Padding for clearer visibility */
}

/* Table Item Styling */
QTableWidget::item {
    padding: 5px; /* Add padding for table cells */
    text-align: left; /* Align text to the left for readability */
}

/* Selected Cell Styling */
QTableWidget::item:selected {
    background-color: #5a9bd6; /* Lighter blue for selected cell */
    color: #ffffff; /* White text for better contrast */
}

/* Scrollbar Styling */
QTableWidget QScrollBar:vertical, QTableWidget QScrollBar:horizontal {
    background-color: #d0e8f2; /* Light blue scrollbar background */
    border: none;
    width: 12px;
}

QTableWidget QScrollBar::handle {
    background: #4682b4; /* Medium blue for scrollbar handle */
    border-radius: 5px;
}

QTableWidget QScrollBar::handle:hover {
    background: #5a9bd6; /* Lighter blue handle on hover */
}

QTableWidget QScrollBar::add-line, QTableWidget QScrollBar::sub-line {
    background: #4682b4; /* Medium blue for arrow buttons */
    border: none;
    width: 12px;
    height: 12px;
}

QTableWidget QScrollBar::add-line:hover, QTableWidget QScrollBar::sub-line:hover {
    background: #5a9bd6; /* Lighter blue on hover */
}
</string>
