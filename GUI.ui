  <property name="styleSheet">
   <string notr="true">/* General Application Background */
QWidget {
    background-color: #d0e8f2; /* Cool light blue for a calming background */
    font-family: 'Comic Sans MS', 'Arial', sans-serif; /* Kid-friendly font */
    color: #1a3c6e; /* Dark blue for text */
}

/* Line Edit Styles */
QLineEdit {
    background-color: #ffffff; /* White for clear input visibility */
    border: 2px solid #4682b4; /* Medium blue border */
    border-radius: 5px;
    padding: 5px;
    font-size: 16px;
    color: #1a3c6e; /* Dark blue for text */
}

QLineEdit:focus {
    border: 2px solid #1a3c6e; /* Highlight border with dark blue on focus */
    background-color: #f0faff; /* Very light blue when focused */
}

/* Button Styles */
QPushButton {
    background-color: #4682b4; /* Medium blue */
    color: white;
    border: 2px solid #1a3c6e; /* Dark blue border */
    border-radius: 10px;
    padding: 10px;
    font-size: 16px;
}

QPushButton#pushButton_16 {
    background-color: #4682b4; /* Medium blue */
    color: white;
	border:none;
    font-size: 48px;
}

QPushButton:hover {
    background-color: #5a9bd6; /* Lighter blue on hover */
}

QPushButton:pressed {
    background-color: #1a3c6e; /* Dark blue when pressed */
    border: 2px solid #ffffff; /* White border when pressed */
}

QLabel {
    font-size: 22px;
    color: #1a3c6e; /* Dark blue for better visibility */
    padding: 5px;
    border: none; /* Ensure labels have no borders */
}

QLabel#label {
    font-size: 35px;
    color: #1a3c6e; /* Dark blue for better visibility */
    padding: 5px;
}

QLabel#label_2 {
    font-size: 35px;
    color: #1a3c6e; /* Dark blue for better visibility */
    padding: 5px;
}

/* Frames and Group Boxes */
QFrame, QGroupBox {
    border: 2px solid #4682b4; /* Medium blue border */
    border-radius: 10px;
    background-color: #f0faff; /* Very light blue background */
    padding: 10px;
}

/* Frames and Group Boxes */
QFrame#frame_6{
    border: 2px solid #4682b4; /* Medium blue border */
    border-radius: 10px;
}

/* CheckBox and RadioButton Styles */
QCheckBox, QRadioButton {
    font-size: 16px;
    color: #1a3c6e; /* Dark blue */
}

QCheckBox::indicator:checked, QRadioButton::indicator:checked {
    background-color: #4682b4; /* Medium blue check indicator */
    border: 1px solid #1a3c6e;
}

/* Slider Styles */
QSlider::groove:horizontal, QSlider::groove:vertical {
    background-color: #4682b4; /* Medium blue groove */
    height: 8px;
}

QSlider::handle:horizontal, QSlider::handle:vertical {
    background: #1a3c6e; /* Dark blue handle */
    border: 2px solid #ffffff;
    width: 16px;
    height: 16px;
    margin: -5px 0; /* Center the handle */
    border-radius: 8px;
}

QSlider::handle:hover {
    background: #5a9bd6; /* Lighter blue handle on hover */
}

QScrollBar:vertical, QScrollBar:horizontal {
    background-color: #d0e8f2; /* Cool light blue for scrollbar background */
    border: none;
    width: 12px;
}

QScrollBar::handle {
    background: #4682b4; /* Medium blue for scrollbar handle */
    border-radius: 5px;
}

QScrollBar::handle:hover {
    background: #5a9bd6; /* Lighter blue on hover */
}

QComboBox {
    background-color: #ffffff; /* White background for clarity */
    border: 2px solid #4682b4; /* Medium blue border */
    border-radius: 5px;
    padding: 5px;
    font-size: 16px;
    color: #1a3c6e; /* Dark blue text */
}

QComboBox:hover {
    border: 2px solid #1a3c6e; /* Dark blue border on hover */
}

QComboBox:focus {
    border: 2px solid #5a9bd6; /* Highlighted lighter blue border */
    background-color: #f0faff; /* Very light blue when focused */
}

QComboBox::drop-down {
    border: none; /* Removes extra border for the drop-down button */
    background-color: #4682b4; /* Medium blue for the button */
    width: 30px;
}

QComboBox::down-arrow {
	image: url(:/icons/assets/icons/down-arrow.png);
    width: 12px;
    height: 12px;
}

QComboBox QAbstractItemView {
    background-color: #ffffff; /* White background for drop-down list */
    border: 2px solid #4682b4; /* Medium blue border for list */
    color: #1a3c6e; /* Dark blue text for items */
    selection-background-color: #5a9bd6; /* Lighter blue for selected item */
    selection-color: #ffffff; /* White text for selected item */
}

/* TextEdit Styles */
QTextEdit {
    background-color: #ffffff; /* White for a clean and clear input area */
    border: 2px solid #4682b4; /* Medium blue border */
    border-radius: 5px;
    padding: 10px;
    font-size: 16px;
    color: #1a3c6e; /* Dark blue text */
    font-family: 'Comic Sans MS', 'Arial', sans-serif; /* Kid-friendly font */
}

QTextEdit:focus {
    border: 2px solid #1a3c6e; /* Highlight border with dark blue on focus */
    background-color: #f0faff; /* Very light blue background when focused */
}

/* Scrollbar Styling for QTextEdit */
QTextEdit QScrollBar:vertical, QTextEdit QScrollBar:horizontal {
    background-color: #d0e8f2; /* Light blue scrollbar background */
    border: none;
    width: 12px;
}

QTextEdit QScrollBar::handle {
    background: #4682b4; /* Medium blue for scrollbar handle */
    border-radius: 5px;
}

QTextEdit QScrollBar::handle:hover {
    background: #5a9bd6; /* Lighter blue handle on hover */
}

QTextEdit QScrollBar::add-line, QTextEdit QScrollBar::sub-line {
    background: #4682b4; /* Medium blue for arrow buttons */
    border: none;
    width: 12px;
    height: 12px;
}

QTextEdit QScrollBar::add-line:hover, QTextEdit QScrollBar::sub-line:hover {
    background: #5a9bd6; /* Lighter blue on hover */
}
</string>
